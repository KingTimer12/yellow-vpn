# Android build artifacts + gradle cache — regenerated by the build, never commit
# (a stale APK/.class blob here is what previously broke a push with >100 MB files)
src-tauri/gen/android/app/build/
src-tauri/gen/android/build/
src-tauri/gen/android/buildSrc/build/
src-tauri/gen/android/**/.gradle/
src-tauri/gen/android/app/src/main/jniLibs/**/*.so