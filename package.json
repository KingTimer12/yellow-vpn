{
  "name": "yellow-vpn",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "predev:helper": "cargo build -p vpn-helper && node -e \"const fs=require('fs');const src='src-tauri/resources/wintun.dll';const dst='target/debug/wintun.dll';if(fs.existsSync(src)){fs.copyFileSync(src,dst);}else{console.warn('WARNING: '+src+' not found; skipping copy. See src-tauri/resources/README.txt');}\"",
    "prebuild:helper": "cargo build -p vpn-helper --release && node -e \"require('fs').copyFileSync('target/release/yellow-vpn-helper.exe','src-tauri/resources/yellow-vpn-helper.exe')\"",
    "tauri:build": "npm run prebuild:helper && tauri build"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "@tauri-apps/cli": "^2"
  }
}
